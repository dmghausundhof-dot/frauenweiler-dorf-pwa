# Supabase Configuration for Frauenweiler DorfApp
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Nur Server (z. B. Vercel): für „Konto löschen“ im Profil (auth.admin.deleteUser).
# Niemals NEXT_PUBLIC_* verwenden und nicht ins Repo committen.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Edge Functions (Supabase Dashboard → Project → Edge Functions → Secrets), für E-Mail-Link zur Kontolöschung:
# RESEND_API_KEY=...
# RESEND_FROM=DorfApp <noreply@deine-domain.de>   (oder Resend-Test: onboarding@resend.dev)
# PUBLIC_SITE_URL=https://deine-dorfapp.vercel.app   (öffentliche URL der Next-App, ohne Slash am Ende)

# After setting these, run the schema.sql in your Supabase SQL Editor
# Then create a public storage bucket called "event-images"
